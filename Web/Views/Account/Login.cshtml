@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-wrapper">
    <div class="auth-header">
        <h1>Welcome Back</h1>
        <p>Sign in to continue your journey.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form asp-controller="Account" asp-action="Login" method="post">
        <div class="press-form-group">
            <label asp-for="Email" class="press-label"></label>
            <input asp-for="Email" class="press-input" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="press-form-group">
            <label asp-for="Password" class="press-label"></label>
            <input type="password" asp-for="Password" class="press-input" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <button type="submit" class="press-btn">Sign In</button>
    </form>

    <div class="auth-footer">
        <span>Don't have an account? </span>
        <a asp-action="Register" asp-controller="Account">Register here</a>
    </div>
</div>
@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-wrapper">
    <div class="auth-header">
        <h1>Join the Press</h1>
        <p>Create an account to begin publishing and reading.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form asp-controller="Account" asp-action="Register" method="post">
        <div class="press-form-group">
            <label asp-for="Email" class="press-label"></label>
            <input asp-for="Email" class="press-input" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="press-form-group">
            <label asp-for="Username" class="press-label"></label>
            <input asp-for="Username" class="press-input" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>
        <div class="press-form-group">
            <label asp-for="Password" class="press-label"></label>
            <input type="password" asp-for="Password" class="press-input" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="press-form-group">
            <label asp-for="ConfirmPassword" class="press-label"></label>
            <input type="password" asp-for="ConfirmPassword" class="press-input" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        <div class="press-form-group">
            <label asp-for="Role" class="press-label"></label>
            <select asp-for="Role" class="press-input">
                <option value="Reader">Reader</option>
                <option value="Author">Author</option>
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>
        <button type="submit" class="press-btn">Create Account</button>
    </form>

    <div class="auth-footer">
        <span>Already have an account? </span>
        <a asp-action="Login" asp-controller="Account">Sign in</a>
    </div>
</div>